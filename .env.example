# Copy this file to .env.local and fill values from your secret store.
# Never commit .env.local, and never paste real values into agent chat.

# Genesys Cloud Terraform provider credentials.
GENESYSCLOUD_OAUTHCLIENT_ID=
GENESYSCLOUD_OAUTHCLIENT_SECRET=

# Genesys Cloud region for the target org, for example:
# us-east-1, us-west-2, eu-west-1, eu-central-1, ap-southeast-2
GENESYSCLOUD_REGION=

# Optional: set Terraform input variables through environment variables.
# TF_VAR_example_name=

# Optional: add backend-specific environment variables locally if your
# Terraform backend requires them. Do not commit backend credentials.
